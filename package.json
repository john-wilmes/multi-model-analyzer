{
  "name": "multi-model-analyzer",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "mma": "apps/cli/dist/index.js"
  },
  "files": [
    "apps/cli/dist",
    "apps/dashboard/dist",
    "packages/*/dist",
    "packages/models/*/dist"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "workspaces": [
    "packages/core",
    "packages/ingestion",
    "packages/parsing",
    "packages/structural",
    "packages/heuristics",
    "packages/summarization",
    "packages/storage",
    "packages/models/config",
    "packages/models/fault",
    "packages/models/functional",
    "packages/diagnostics",
    "packages/query",
    "packages/mcp",
    "apps/cli",
    "apps/dashboard"
  ],
  "scripts": {
    "build": "tsc --build",
    "build:dashboard": "npm run build -w apps/dashboard",
    "type-check": "tsc --build --noEmit",
    "lint": "eslint packages/ apps/",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "validate:models": "vitest run --config validation/vitest.validation.ts",
    "clean": "tsc --build --clean",
    "setup": "bash scripts/setup.sh",
    "prepare": "husky",
    "prepublishOnly": "npm run build && npm run test"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.0.0",
    "husky": "^9.1.7",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.0.0"
  },
  "overrides": {
    "rollup": ">=4.59.0",
    "minimatch@<3.1.4": "3.1.4",
    "minimatch@>=9.0.0 <9.0.7": "9.0.7",
    "minimatch@>=10.0.0 <10.2.3": "10.2.3",
    "ajv@>=6.0.0 <6.14.0": "6.14.0"
  }
}
